# Storage
# Use sqlite for local development, supabase for production/Postgres.
LEMTIK_STORAGE=supabase

# Supabase database connection. Prefer the transaction pooler URL for deployed apps.
SUPABASE_DB_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
SUPABASE_POOLER_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=
SUPABASE_SSLMODE=require
POSTGRES_CONNECT_TIMEOUT=8
POSTGRES_POOL_MIN=1
POSTGRES_POOL_MAX=5
LEMTIK_DEFAULT_ORG_ID=default
# Optional: set this only if you want Postgres RLS scoped at connection level.
LEMTIK_RLS_ORG_ID=

# Optional FastAPI API keys. If blank, local brain API stays open.
# Format: raw-key:org_id:role:name,raw-key-2:org_id:role:name
LEMTIK_API_KEYS=

# Resend email delivery
RESEND_API_KEY=re_your_resend_api_key
LEMTIK_BRIEF_EMAIL_FROM=briefs@your-domain.com
LEMTIK_BRIEF_EMAIL_TO=client@example.com,analyst@example.com
LEMTIK_ALERT_EMAIL_FROM=alerts@your-domain.com
LEMTIK_ALERT_EMAIL_TO=security-manager@example.com,analyst@example.com
LEMTIK_ALERT_WORKER_INTERVAL_SECONDS=60
LEMTIK_ALERT_RETRY_MINUTES=15

# Optional Supabase client settings for future API work
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Local server
LEMTIK_HOST=127.0.0.1
LEMTIK_PORT=8765

# FastAPI brain service
LEMTIK_BRAIN_HOST=127.0.0.1
LEMTIK_BRAIN_PORT=8770
LEMTIK_DASHBOARD_CACHE_SECONDS=30

# NLP backends. spaCy is attempted when installed; Transformers is opt-in
# because it loads a heavier model.
LEMTIK_ENABLE_SPACY=1
LEMTIK_ENABLE_TRANSFORMERS=0
LEMTIK_TRANSFORMERS_MODEL=distilbert-base-uncased-finetuned-sst-2-english
LEMTIK_TRANSFORMERS_DEVICE=-1
